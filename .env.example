# ============================================================
# Rate Radar — environment variables
# Copy to .env for local use. In production these live in two places:
#   Vercel  → Project Settings → Environment Variables (site + ingest vars)
#   GitHub  → Repo Settings → Secrets and variables → Actions (collector vars)
# ============================================================

# --- Site access ---
# The single shared password your family types into the login page. Pick anything strong.
SITE_PASSWORD=change-me

# Secret used to sign the login cookie. Generate: openssl rand -hex 32
SESSION_SECRET=

# Bearer token the GitHub Actions collector uses to push data into /api/ingest.
# Generate: openssl rand -hex 32. Must be identical in Vercel AND GitHub secrets.
INGEST_SECRET=

# --- Storage (Upstash Redis via Vercel Marketplace) ---
# Vercel dashboard → Storage → Create Database → Upstash (Redis) → link to project.
# Vercel injects these automatically in production; copy them here only for local dev.
# Leave BOTH blank locally to use a .data/store.json file instead (demo mode).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# --- Email (Resend, free tier) ---
# Key from resend.com → API Keys.
RESEND_API_KEY=
# Who gets alerts. NOTE: without a verified domain, Resend free tier only
# delivers to the email address that OWNS the Resend account. Create the
# Resend account with the address you want alerts sent to. If you later
# verify a domain, this can be any list: a@x.com,b@y.com
ALERT_EMAIL_TO=
# Public URL of the deployed dashboard (used in the email footer link).
DASHBOARD_URL=https://your-project.vercel.app

# --- Event data APIs ---
# Free key: developer.ticketmaster.com → Get Your API Key (Discovery API).
# Use the "Consumer Key" — the consumer secret is NOT needed.
TICKETMASTER_API_KEY=
# Free key: collegefootballdata.com → API Keys (emailed to you).
CFBD_API_KEY=
# api.weather.gov requires a descriptive User-Agent identifying you + contact.
NWS_USER_AGENT=RateRadar-RRI1430 (your-email@example.com)

# --- DigitalFingerprint (OriginID) visitor identification (optional) ---
# Official CDN script-tag integration (SRI-pinned), landing page only.
# Identification stays OFF until the public key below is set.
# PUBLIC pk_ key — browser-visible by design (hostname-allowlisted).
NEXT_PUBLIC_ORIGINID_PUBLIC_KEY=
# Optional override of the SDK script source (self-hosted/first-party proxy);
# leave blank to use https://cdn.digitalfingerprintjs.com/v1/originid.global.js
NEXT_PUBLIC_ORIGINID_SCRIPT_URL=
# SECRET sk_ key for the server-side Events API (GET /api/events/{eventId}).
# Server only — NEVER expose as NEXT_PUBLIC_*.
ORIGINID_SECRET_API_KEY=

# --- Rate parity check URLs (this property: RRI1430, 3915 Carothers Pkwy) ---
# Dates in these URLs are rewritten to tomorrow automatically on every run.
RATE_URL_REDROOF="https://www.redroof.com/checkout/select-rooms?destId=RRI1430&locSrc=gm&numAdults=1&numChildrenTotal=0&roomCount=1&checkInFormatted=2026-07-12&checkOutFormatted=2026-07-13&stayRatePlanType=Daily&useRediCard=false&roomDetails=%5B%7B%22adults%22%3A1%2C%22kids%22%3A0%7D%5D&isHTSOnly=false"
RATE_URL_EXPEDIA="https://www.expedia.com/Nashville-Hotels-Days-Inn-By-Wyndham-Franklin-Nashville.h42914.Hotel-Information?chkin=2026-07-26&chkout=2026-07-27&rm1=a2"
RATE_URL_BOOKING="https://www.booking.com/hotel/us/franklin-3915-carothers-parkway-days-inn-franklin.html?checkin=2026-07-26&checkout=2026-07-27&group_adults=2&no_rooms=1"
# Google Hotels has no stable URL — the collector searches by name.
GOOGLE_HOTELS_QUERY="Red Roof Inn Franklin TN 3915 Carothers Parkway"
